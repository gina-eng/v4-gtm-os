# ===========================================================================
# V4 GTM OS — variáveis de ambiente
# ---------------------------------------------------------------------------
# Copie este arquivo para `.env.local` (que é gitignored) e preencha os valores.
#
#   cp .env.example .env.local
#
# Não commite `.env.local` nem credenciais reais neste arquivo.
# ===========================================================================

# ----- Supabase / Postgres ------------------------------------------------
# DATABASE_URL: connection string usada pelo app em runtime (Next.js).
# No Supabase, prefira a "Transaction Pooler" (porta 6543) para o app.
#
# Exemplo (Supabase Transaction Pooler):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# DATABASE_URL_DIRECT: usada pelas migrations (drizzle-kit).
# Migrations rodam DDL e precisam da "Direct Connection" (porta 5432),
# porque o pooler em modo transaction não suporta prepared statements
# nem comandos administrativos.
#
# Exemplo (Supabase Direct Connection):
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_DIRECT=

